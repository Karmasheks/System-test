# PostgreSQL (Amvera или любой хост) — sslmode=require для Amvera
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
PGHOST=HOST
PGPORT=5432
PGUSER=USER
PGPASSWORD=PASSWORD
PGDATABASE=DATABASE

NODE_ENV=development
PORT=5000
# Локально: http://127.0.0.1:5000
# Amvera: NODE_ENV=production, containerPort=80, переменную PORT НЕ задавать (или PORT=80)

JWT_SECRET=8f3a9d2c7e1b4a6f9c2d8e7f1a3b5c6d9e2f4a7b1c8d3e6f
SESSION_SECRET=7c2e9a4d1f8b3c6e5a9d2f7b4c1e8a6d3f9b2c7e4a1d5f8b

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=your_bot_username
# 1 = long polling. 0 = webhook. На Amvera обычно не работает без TELEGRAM_ENABLE_WEBHOOK=1.
TELEGRAM_USE_POLLING=0
# TELEGRAM_ENABLE_WEBHOOK=1
TELEGRAM_WEBHOOK_SECRET=случайная_длинная_строка
APP_PUBLIC_URL=https://ваш-домен.amvera.io

# --- только локально (npm run deploy:amvera), НЕ добавлять в панель Amvera ---
AMVERA_GIT_USER=ваш_логин_amvera
AMVERA_GIT_PASSWORD=ваш_пароль_или_токен_git